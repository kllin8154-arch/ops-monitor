# OpsMonitor environment example.
# Copy this file to .env for local reference. Do not commit real .env files.

# Use "production" to enable stricter startup checks in sensitive deployments.
OPS_ENV=development

# Initial OpsMonitor admin password. Change before any shared or public deployment.
OPS_ADMIN_PASSWORD=ChangeMe_Admin_123!

# Grafana admin password. Change before any shared or public deployment.
OPS_GRAFANA_PASSWORD=ChangeMe_Grafana_123!

# HMAC signing secret, at least 32 random characters.
OPS_HMAC_SECRET=replace-with-at-least-32-random-characters

# AlertManager webhook shared secret. Recommended for production.
OPS_WEBHOOK_SECRET=replace-with-random-webhook-secret

# Docker Compose project name.
OPS_PROJECT_NAME=ops-monitor

# SSH runbook security. Use "yes" and configure known hosts for production.
OPS_SSH_STRICT_HOST_KEY=no
OPS_SSH_KNOWN_HOSTS=
OPS_SSH_CONNECT_TIMEOUT=10
OPS_SSH_EXEC_TIMEOUT=30
