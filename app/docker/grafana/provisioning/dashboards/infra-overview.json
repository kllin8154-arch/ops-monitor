    "fieldConfig" : {
      "defaults" : {
        "custom" : {
          "hideFrom" : {
            "legend" : false,
            "tooltip" : false,
            "viz" : false
          }
        }
      }
    }
  }, {
    "id" : 12,
    "title" : "内存使用率热力图（多实例分布）",
    "type" : "heatmap",
    "description" : "Y轴：内存使用率区间。X轴：时间。颜色深度表示集群内存压力分布。",
    "gridPos" : {
      "h" : 8,
      "w" : 12,
      "x" : 12,
      "y" : 8
    },
    "datasource" : {
      "type" : "prometheus",
      "uid" : "VictoriaMetrics"
    },
    "targets" : [ {
      "expr" : "(1 - node_memory_MemAvailable_bytes{server_name=~\"$server_name\"} / node_memory_MemTotal_bytes{server_name=~\"$server_name\"}) * 100",
      "legendFormat" : "{{server_name}}",
      "refId" : "A"
