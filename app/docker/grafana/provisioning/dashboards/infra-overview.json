      "legendFormat" : "{{server_name}}",
      "refId" : "A"
    }, {
      "expr" : "100 - (sum by(server_name)(rate(windows_cpu_time_total{mode=\"idle\",server_name=~\"$server_name\"}[5m])) / sum by(server_name)(rate(windows_cpu_time_total{server_name=~\"$server_name\"}[5m])) * 100)",
      "legendFormat" : "{{server_name}} (Win)",
