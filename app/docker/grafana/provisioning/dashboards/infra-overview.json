    "targets" : [ {
      "expr" : "clamp_min(100 - (avg by(server_name)(irate(node_cpu_seconds_total{mode=\"idle\",server_name=~\"$server_name\"}[2m])) * 100), 0)",
      "legendFormat" : "{{server_name}}",
      "refId" : "A"
    } ],
    "options" : {
