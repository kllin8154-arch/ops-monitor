    },
    "targets" : [ {
      "expr" : "(1 - node_memory_MemAvailable_bytes{server_name=~\"$server_name\"} / node_memory_MemTotal_bytes{server_name=~\"$server_name\"}) * 100",
      "legendFormat" : "{{server_name}}",
      "refId" : "A"
    }, {
      "expr" : "(1 - windows_os_physical_memory_free_bytes{server_name=~\"$server_name\"} / windows_cs_physical_memory_bytes{server_name=~\"$server_name\"}) * 100",
      "legendFormat" : "{{server_name}} (Win)",
